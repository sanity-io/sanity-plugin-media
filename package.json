{
  "name": "sanity-plugin-media",
  "version": "4.2.0",
  "description": "This version of `sanity-plugin-media` is for Sanity Studio V3.",
  "keywords": [
    "sanity",
    "cms",
    "headless",
    "realtime",
    "content",
    "sanity-plugin",
    "asset",
    "browser"
  ],
  "homepage": "https://github.com/sanity-io/sanity-plugin-media#readme",
  "bugs": {
    "url": "https://github.com/sanity-io/sanity-plugin-media/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:sanity-io/sanity-plugin-media.git"
  },
  "license": "MIT",
  "author": "Sanity.io <hello@sanity.io>",
  "type": "commonjs",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "sanity.json",
    "src",
    "v2-incompatible.js"
  ],
  "scripts": {
    "build": "plugin-kit verify-package --silent && pkg-utils build --strict --check --clean",
    "clean": "rimraf dist",
    "dev": "sanity dev",
    "format": "prettier --write --cache --ignore-unknown .",
    "link-watch": "plugin-kit link-watch",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky install",
    "prepublishOnly": "npm run build",
    "watch": "pkg-utils watch --strict"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@sanity/client": "^7.22.0",
    "@sanity/color": "^3.0.6",
    "@sanity/icons": "^3.7.4",
    "@sanity/incompatible-plugin": "^1.0.5",
    "@sanity/ui": "^3.2.0",
    "@sanity/uuid": "^3.0.2",
    "@tanem/react-nprogress": "^5.0.63",
    "copy-to-clipboard": "^3.3.3",
    "date-fns": "^4.1.0",
    "filesize": "^9.0.11",
    "groq": "^3.99.0",
    "is-hotkey-esm": "^1.0.0",
    "nanoid": "^3.3.12",
    "pluralize": "^8.0.0",
    "react-dropzone": "^11.7.1",
    "react-file-icon": "^1.6.0",
    "react-hook-form": "^7.75.0",
    "react-redux": "^9.2.0",
    "react-select": "^5.10.2",
    "react-virtuoso": "^4.18.6",
    "redux": "^5.0.1",
    "redux-observable": "3.0.0-rc.3",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.8.1",
    "@commitlint/config-conventional": "^17.8.1",
    "@sanity/pkg-utils": "^7.11.9",
    "@sanity/plugin-kit": "^4.0.20",
    "@sanity/semantic-release-preset": "^2.0.5",
    "@sanity/vision": "^3.99.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/is-hotkey": "^0.1.10",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-file-icon": "^1.0.5",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "conventional-changelog-conventionalcommits": "^5.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-config-sanity": "^6.0.0",
    "eslint-plugin-prettier": "^4.2.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "husky": "^8.0.3",
    "jsdom": "^25.0.1",
    "lint-staged": "^13.3.0",
    "prettier": "^2.8.8",
    "prettier-plugin-packagejson": "^2.5.22",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-is": "^19.2.5",
    "rimraf": "^3.0.2",
    "sanity": "^3.99.0",
    "standard-version": "^9.5.0",
    "styled-components": "^6.4.1",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "react": "^18.3 || ^19",
    "react-dom": "^18.3 || ^19",
    "react-is": "^18.3 || ^19",
    "sanity": "^3.78 || ^4.0.0-0 || ^5",
    "styled-components": "^6.1"
  },
  "engines": {
    "node": ">=18"
  }
}
